{
	"name": "cue-bit",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
		"test:physics": "vite build --ssr scripts/physics_regression_test.ts --outDir .tmp/physics-test --emptyOutDir && node .tmp/physics-test/physics_regression_test.js",
		"preview": "vite preview",
		"predeploy": "npm run build",
		"deploy": "gh-pages -d dist"
	},
	"dependencies": {
		"@techstark/opencv-js": "4.12.0-release.1",
		"@types/dom-mediacapture-transform": "^0.1.11",
		"chii": "^1.15.5",
		"modern-normalize": "^3.0.1",
		"pino": "^10.3.1",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-router": "^7.13.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@eslint/js": "^9.39.1",
		"@types/node": "^24.10.1",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react-swc": "^4.2.2",
		"eslint": "^9.39.1",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.4.24",
		"gh-pages": "^6.3.0",
		"globals": "^16.5.0",
		"typescript": "~5.9.3",
		"typescript-eslint": "^8.48.0",
		"vite": "^7.3.1",
		"vite-tsconfig-paths": "^6.1.1"
	}
}
